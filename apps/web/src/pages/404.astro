---
import BusinessLayout from '../layouts/BusinessLayout.astro';
---

<BusinessLayout title="Negocio no encontrado | Nexlynk">
  <main class="max-w-lg mx-auto px-4 py-16 text-center">
    <div class="mb-8">
      <h1 class="text-6xl font-bold text-gray-300 mb-4">404</h1>
      <p class="text-xl text-gray-600 mb-2">Negocio no encontrado</p>
      <p class="text-gray-500">
        Este enlace no existe o el negocio no está activo.
      </p>
    </div>

    <a
      href="/"
      class="btn-primary inline-block"
    >
      Volver al inicio
    </a>
  </main>
</BusinessLayout>
