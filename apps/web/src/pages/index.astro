---
import BusinessLayout from '../layouts/BusinessLayout.astro';
---

<BusinessLayout title="Nexlynk - El enlace entre tu negocio y el mundo">
  <main class="max-w-lg mx-auto px-4 py-16 text-center">
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        Nexlynk
      </h1>
      <p class="text-xl text-gray-600">
        El enlace entre tu negocio y el mundo
      </p>
    </div>

    <div class="card max-w-md mx-auto">
      <p class="text-gray-600 mb-6">
        Crea tu página de negocios gratuita en segundos.
      </p>
      <a
        href="https://nexlynk-admin.vercel.app/register"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary inline-block"
      >
        Crear mi página
      </a>
    </div>

    <div class="mt-12 text-sm text-gray-500">
      <p>Ingresa a tu página de negocio directamente:</p>
      <p class="mt-2">
        <span class="text-brand font-medium">nexlynk.pages.dev</span>/<strong>tu-negocio</strong>
      </p>
    </div>
  </main>
</BusinessLayout>
