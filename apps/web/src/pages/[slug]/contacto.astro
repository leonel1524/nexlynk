---
import BusinessLayout from '../../layouts/BusinessLayout.astro';

const API_URL = import.meta.env.API_URL || 'http://localhost:3000/api';
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

let business;

try {
  const response = await fetch(`${API_URL}/businesses/public/${slug}`);

  if (!response.ok) {
    return Astro.redirect('/404');
  }

  business = await response.json();
} catch (error) {
  console.error('Error fetching business:', error);
  return Astro.redirect('/404');
}
---

<BusinessLayout
  title={`Contacto - ${business.name} | Nexlynk`}
  description={`Contacta a ${business.name}`}
>
  <main class="max-w-lg mx-auto px-4 py-8">
    {/* Header */}
    <div class="mb-8">
      <a href={`/${slug}`} class="text-brand hover:underline text-sm font-medium flex items-center gap-1 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Contáctanos</h1>
      <p class="text-gray-600 mt-1">Estamos aquí para ayudarte</p>
    </div>

    {/* Contact Info */}
    <div class="space-y-4 mb-8">
      {business.phone && (
        <a href={`tel:${business.phone.replace(/\D/g, '')}`} class="card card-hover flex items-center gap-4">
          <div class="w-12 h-12 bg-blue-500/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-gray-900">Teléfono</p>
            <p class="text-gray-600">{business.phone}</p>
          </div>
        </a>
      )}

      {business.email && (
        <a href={`mailto:${business.email}`} class="card card-hover flex items-center gap-4">
          <div class="w-12 h-12 bg-brand/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-gray-900">Email</p>
            <p class="text-gray-600">{business.email}</p>
          </div>
        </a>
      )}

      {business.whatsapp && (
        <a
          href={`https://wa.me/${business.whatsapp.replace(/\D/g, '')}?text=${encodeURIComponent('¡Hola! Me gustaría información sobre sus servicios.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="card card-hover flex items-center gap-4"
        >
          <div class="w-12 h-12 bg-green-500/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-gray-900">WhatsApp</p>
            <p class="text-gray-600">{business.whatsapp}</p>
          </div>
        </a>
      )}
    </div>

    {/* Contact Form */}
    <div class="card">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Envíanos un mensaje</h2>
      <form id="contact-form" class="space-y-4">
        <div>
          <label for="name" class="label">Nombre</label>
          <input type="text" id="name" name="name" required class="input-field" placeholder="Tu nombre" />
        </div>
        <div>
          <label for="email" class="label">Email</label>
          <input type="email" id="email" name="email" required class="input-field" placeholder="tu@email.com" />
        </div>
        <div>
          <label for="phone" class="label">Teléfono (opcional)</label>
          <input type="tel" id="phone" name="phone" class="input-field" placeholder="+1 234 567 890" />
        </div>
        <div>
          <label for="message" class="label">Mensaje</label>
          <textarea id="message" name="message" rows="4" required class="input-field" placeholder="¿En qué podemos ayudarte?"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full">
          Enviar mensaje
        </button>
      </form>
      <div id="form-success" class="hidden mt-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm">
        ¡Mensaje enviado correctamente! Te contactaremos pronto.
      </div>
      <div id="form-error" class="hidden mt-4 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg text-sm">
        Error al enviar el mensaje. Por favor, intenta de nuevo.
      </div>
    </div>

    {/* Footer */}
    <footer class="mt-16 pt-8 border-t border-gray-200 text-center">
      <img src="/isologo.png" alt="Nexlynk" class="mx-auto mb-3 h-8 w-auto opacity-60" />
      <p class="text-sm text-gray-500">
        Creado con{' '}
        <a href="https://nexlynk.app" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">
          Nexlynk
        </a>
      </p>
    </footer>
  </main>

  <script define:vars={{ businessId: business.id }}>
    const form = document.getElementById('contact-form');
    const successMsg = document.getElementById('form-success');
    const errorMsg = document.getElementById('form-error');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        phone: formData.get('phone') || undefined,
        message: formData.get('message'),
      };

      try {
        const response = await fetch(`${window.location.origin}/api/businesses/${businessId}/contact`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          form.reset();
          successMsg.classList.remove('hidden');
          errorMsg.classList.add('hidden');
        } else {
          throw new Error('Error');
        }
      } catch (error) {
        errorMsg.classList.remove('hidden');
        successMsg.classList.add('hidden');
      }
    });
  </script>
</BusinessLayout>
