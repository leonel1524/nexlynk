---
import BusinessLayout from '../../layouts/BusinessLayout.astro';
import LocationCard from '../../components/LocationCard.astro';
import Footer from '../../components/Footer.astro';

const API_URL = import.meta.env.API_URL || 'http://localhost:3000/api';
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

let business;

try {
  const response = await fetch(`${API_URL}/businesses/public/${slug}`);

  if (!response.ok) {
    return Astro.redirect('/404');
  }

  business = await response.json();
} catch (error) {
  console.error('Error fetching business:', error);
  return Astro.redirect('/404');
}
---

<BusinessLayout
  title={`Ubicaciones - ${business.name} | Nexlynk`}
  description={`Encuentra las ubicaciones de ${business.name}`}
>
  <main class="max-w-lg mx-auto px-4 py-8">
    {/* Header */}
    <div class="mb-8">
      <a href={`/${slug}`} class="text-brand hover:underline text-sm font-medium flex items-center gap-1 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Ubicaciones</h1>
      <p class="text-gray-600 mt-1">Encuéntranos cerca de ti</p>
    </div>

    {/* Locations List */}
    {business.locations && business.locations.length > 0 ? (
      <div class="space-y-4">
        {business.locations.map((location: any) => (
          <LocationCard
            name={location.name}
            address={location.address}
            phone={location.phone}
            whatsapp={location.whatsapp}
            schedule={location.schedule}
            latitude={location.latitude}
            longitude={location.longitude}
            isMain={location.is_main}
          />
        ))}
      </div>
    ) : (
      <div class="card text-center py-12">
        <p class="text-gray-500">No hay ubicaciones disponibles</p>
      </div>
    )}

    {/* Footer */}
    <Footer />
  </main>
</BusinessLayout>
