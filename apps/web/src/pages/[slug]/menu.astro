---
import BusinessLayout from '../../layouts/BusinessLayout.astro';
import MenuSection from '../../components/MenuSection.astro';

const API_URL = import.meta.env.API_URL || 'http://localhost:3000/api';
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

let business;

try {
  const response = await fetch(`${API_URL}/businesses/public/${slug}`);

  if (!response.ok) {
    return Astro.redirect('/404');
  }

  business = await response.json();
} catch (error) {
  console.error('Error fetching business:', error);
  return Astro.redirect('/404');
}

const menu = business.menus?.[0];

const categories = menu?.menu_categories?.map((cat: any) => ({
  id: cat.id,
  name: cat.name,
  description: cat.description,
  items: cat.menu_items || [],
})) || [];
---

<BusinessLayout
  title={`Menú - ${business.name} | Nexlynk`}
  description={`Menú de ${business.name}`}
>
  <main class="max-w-lg mx-auto px-4 py-8">
    {/* Header */}
    <div class="mb-8">
      <a href={`/${slug}`} class="text-brand hover:underline text-sm font-medium flex items-center gap-1 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Menú</h1>
      <p class="text-gray-600 mt-1">Selecciona tus items favoritos</p>
    </div>

    {/* Menu Content */}
    {categories.length > 0 ? (
      <MenuSection
        categories={categories}
        businessName={business.name}
        whatsapp={business.whatsapp}
      />
    ) : (
      <div class="card text-center py-12">
        <p class="text-gray-500">No hay menú disponible</p>
      </div>
    )}

    {/* Footer */}
    <footer class="mt-16 pt-8 border-t border-gray-200 text-center">
      <img src="/isologo.png" alt="Nexlynk" class="mx-auto mb-3 h-8 w-auto opacity-60" />
      <p class="text-sm text-gray-500">
        Creado con{' '}
        <a href="https://nexlynk.app" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">
          Nexlynk
        </a>
      </p>
    </footer>
  </main>
</BusinessLayout>
