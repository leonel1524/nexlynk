---
export interface Props {
  name: string;
  address: string;
  phone?: string;
  whatsapp?: string;
  schedule?: Record<string, string>;
  latitude?: number;
  longitude?: number;
  isMain?: boolean;
}

const { 
  name, 
  address, 
  phone, 
  whatsapp, 
  schedule, 
  latitude, 
  longitude, 
  isMain = false 
} = Astro.props;

const mapsUrl = latitude && longitude
  ? `https://www.google.com/maps?q=${latitude},${longitude}`
  : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;

const phoneLink = phone ? `tel:${phone.replace(/\D/g, '')}` : null;
const whatsappLink = whatsapp 
  ? `https://wa.me/${whatsapp.replace(/\D/g, '')}` 
  : null;

const scheduleEntries = schedule ? Object.entries(schedule) : [];
---

<div class={`card card-hover ${isMain ? 'ring-2 ring-brand' : ''}`}>
  <div class="flex items-start gap-4">
    <!-- Icon -->
    <div class="flex-shrink-0 w-12 h-12 bg-brand/10 rounded-full flex items-center justify-center">
      <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-gray-900 mb-1">{name}</h3>
      <p class="text-gray-600 text-sm mb-3">{address}</p>

      <!-- Schedule -->
      {scheduleEntries.length > 0 && (
        <div class="mb-3">
          <p class="text-xs font-medium text-gray-500 uppercase mb-1">Horario</p>
          <div class="text-sm text-gray-600">
            {scheduleEntries.map(([day, hours]) => (
              <p><span class="font-medium">{day}:</span> {hours}</p>
            ))}
          </div>
        </div>
      )}

      <!-- Action Buttons -->
      <div class="flex flex-wrap gap-2">
        <!-- Maps Button -->
        <a 
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="maps-btn text-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          Cómo llegar
        </a>

        <!-- Phone Button -->
        {phoneLink && (
          <a 
            href={phoneLink}
            class="bg-gray-100 text-gray-700 px-4 py-2 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Llamar
          </a>
        )}

        <!-- WhatsApp Button -->
        {whatsappLink && (
          <a 
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-btn text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        )}
      </div>
    </div>
  </div>
</div>
