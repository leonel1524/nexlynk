{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && cd apps/api && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd apps/api && node dist/main",
    "healthcheckPath": "/api",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
